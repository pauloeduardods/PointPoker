            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"display_name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rooms/INVALID/join",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "INVALID", "join"]
            },
            "description": "Tenta entrar em uma sala que não existe."
          },
          "response": []
        },
        {
          "name": "Vote with invalid value",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Session-Token",
                "value": "{{host_session_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"value\": \"99\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_code}}/rounds/{{round_id}}/vote",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "rooms",
                "{{room_code}}",
                "rounds",
                "{{round_id}}",
                "vote"
              ]
            },
            "description": "Tenta votar com valor inválido (99 não está no deck Fibonacci)."
          },
          "response": []
        },
        {
          "name": "Non-host tries to reveal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Session-Token",
                "value": "{{participant_session_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_code}}/rounds/{{round_id}}/reveal",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "rooms",
                "{{room_code}}",
                "rounds",
                "{{round_id}}",
                "reveal"
              ]
            },
            "description": "Participante (não-host) tenta revelar votos — deve retornar 403 Forbidden."
          },
          "response": []
        },
        {
          "name": "Missing session token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 or 403', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"value\": \"5\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rooms/{{room_code}}/rounds/{{round_id}}/vote",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "rooms",
                "{{room_code}}",
                "rounds",
                "{{round_id}}",
                "vote"
              ]
            },
            "description": "Tenta votar sem enviar X-Session-Token — deve retornar 401."
          },
          "response": []
        }
      ],
      "description": "Casos de erro para validar tratamento de exceções"
    }
  ]
}
